SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_or_anon_key_here

# Troubleshooting "sign-in loads forever"
# - Values come from Supabase Dashboard → Project Settings → API (Project URL + anon public key).
# - Copy this file to .env in this folder (same level as package.json).
# - Android/iOS: react-native-config is baked in at native build time — run a full rebuild after changing .env
#   (e.g. npx react-native run-android), not only Metro refresh. Wrong URL = requests hang until timeout.
# - The emulator banner "Loading from 10.0.2.2:8081" is Metro (JS bundle), not Supabase; Supabase must still be reachable over HTTPS.
