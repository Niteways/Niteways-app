# Web app (Vite) — copy to `.env` locally. On Railway, set these in the service Variables.

# Production: only Venue Portal UI (hide Admin + User App preview). Rebuild after changing.
VITE_VENUE_PORTAL_ONLY=true

# Alternative: VITE_DEPLOY_MODE=venue_portal_only

# Mapbox (public token for web User App map — get from https://account.mapbox.com/)
VITE_MAPBOX_ACCESS_TOKEN=
