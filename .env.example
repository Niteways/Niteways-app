# Web app (Vite) — copy to `.env` locally. On Railway, set these in the service Variables.

# Production: only Venue Portal UI (hide Admin + User App preview). Rebuild after changing.
VITE_VENUE_PORTAL_ONLY=true

# Alternative: VITE_DEPLOY_MODE=venue_portal_only

# Mapbox (public token for web User App map — get from https://account.mapbox.com/)
VITE_MAPBOX_ACCESS_TOKEN=

# Optional: exact site origin for Supabase auth redirects (password reset). Defaults to browser origin.
# Local Vite dev server uses port 3000 (see vite.config.ts) — allow http://localhost:3000/auth/callback in Supabase.
# Set on Railway to your public URL, e.g. https://your-app.up.railway.app (no trailing slash).
# Must match an entry in Supabase → Authentication → URL configuration (redirect allow list).
VITE_AUTH_REDIRECT_BASE=

# When true, venue routes require Supabase email/password even if VITE_VENUE_PORTAL_ONLY is false (local QA).
VITE_REQUIRE_VENUE_LOGIN=

# Same venue UUID as the native Venue App (Supabase `profiles.venue_id` for staff). Optional; omit uses built-in demo id.
# Railway: this is baked in at `vite build` time — to switch venue without redeploying, open once:
#   https://your-app.up.railway.app/?venue_id=<venues.id>
# (also persisted as sessionStorage `niteways_portal_venue_id` in the browser)
VITE_DEFAULT_VENUE_ID=
